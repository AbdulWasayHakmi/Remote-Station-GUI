<Window x:Class="FYP_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FYP_GUI"
        mc:Ignorable="d"
        Title="Firefighting Robot Teleop" Height="680" Width="1050"
        Background="#F5F5F5" WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════
                 SIDEBAR
            ════════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#DEDEDE"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0"
                    Padding="12">
                <StackPanel>

                    <TextBlock Text="Controls"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#222222" Margin="0,0,0,12"/>

                    <!-- Joystick -->
                    <TextBlock Text="Joystick" FontSize="13" FontWeight="Bold"
                               Foreground="#444444" Margin="0,0,0,6"/>
                    <Border Background="#F0F0F0" CornerRadius="8" Padding="6" Margin="0,0,0,12">
                        <Viewbox Stretch="Uniform" Width="170" Height="170"
                                 HorizontalAlignment="Center">
                            <Canvas x:Name="JoystickCanvas" Width="180" Height="180"
                                    Background="#F0F0F0"
                                    MouseMove="JoystickCanvas_MouseMove"
                                    MouseLeftButtonDown="JoystickCanvas_MouseDown"
                                    MouseLeftButtonUp="JoystickCanvas_MouseUp"
                                    MouseLeave="JoystickCanvas_MouseLeave">
                                <Ellipse Canvas.Left="25" Canvas.Top="25"
                                         Width="130" Height="130"
                                         Fill="Transparent"
                                         Stroke="#BBBBBB" StrokeThickness="1.5"/>
                                <Ellipse x:Name="JoystickKnob"
                                         Canvas.Left="80" Canvas.Top="80"
                                         Width="20" Height="20"
                                         Fill="#E53935"/>
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <Separator Margin="0,0,0,10" Background="#E0E0E0"/>

                    <!-- Action Buttons -->
                    <TextBlock Text="Actions" FontSize="13" FontWeight="Bold"
                               Foreground="#444444" Margin="0,0,0,6"/>
                    <Button x:Name="startButton"
                            Content="Start" Height="32" Margin="0,0,0,6"
                            Background="#1E88E5" Foreground="White"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="stopButton"
                            Content="Stop" Height="32" Margin="0,0,0,6"
                            Background="#E53935" Foreground="White"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>

                    <Separator Margin="0,6,0,10" Background="#E0E0E0"/>

                    <!-- Supervisory Buttons -->
                    <TextBlock Text="Supervisory" FontSize="13" FontWeight="Bold"
                               Foreground="#444444" Margin="0,0,0,6"/>
                    <Button x:Name="EmergencyStopButton"
                            Content="EMERGENCY STOP" Height="36" Margin="0,0,0,6"
                            Background="#B71C1C" Foreground="White"
                            FontWeight="Bold" FontSize="12" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="RecalibrateButton"
                            Content="Recalibrate" Height="32" Margin="0,0,0,6"
                            Background="#F5F5F5" Foreground="#333333"
                            BorderBrush="#BBBBBB" BorderThickness="1" Cursor="Hand"/>
                    <Button x:Name="ReadInitButton"
                            Content="Read Init" Height="32" Margin="0,0,0,12"
                            Background="#F5F5F5" Foreground="#333333"
                            BorderBrush="#BBBBBB" BorderThickness="1" Cursor="Hand"/>

                    <Separator Margin="0,0,0,10" Background="#E0E0E0"/>

                    <!-- Serial Connection -->
                    <TextBlock Text="Serial Connection" FontSize="13" FontWeight="Bold"
                               Foreground="#444444" Margin="0,0,0,6"/>
                    <ComboBox x:Name="PortComboBox" Height="28" IsEditable="True" Margin="0,0,0,6"/>
                    <ComboBox x:Name="BaudComboBox" Height="28" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ParityComboBox" Height="28" Margin="0,0,0,8"/>

                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                        <ToggleButton x:Name="ConnectButton"
                                      Content="Connect" Width="95" Height="28"
                                      DockPanel.Dock="Left" Margin="0,0,6,0"
                                      Background="#1E88E5" Foreground="White"
                                      FontWeight="Bold" BorderThickness="0"/>
                        <Button x:Name="RefreshPortsButton"
                                Content="Refresh" Width="58" Height="28"
                                Background="#F5F5F5" Foreground="#333333"
                                BorderBrush="#BBBBBB" BorderThickness="1"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ConnectionIndicator"
                                 Width="10" Height="10" Fill="#BBBBBB" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Disconnected" Foreground="#777777"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════
                 MAIN CONTENT
            ════════════════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- nRF Feedback Bar -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#DEDEDE" BorderThickness="1"
                        CornerRadius="8" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Delta values -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="nRF Feedback" FontSize="13" FontWeight="Bold"
                                       Foreground="#444444" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="ΔL:" Foreground="#777777" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="NrfDeltaLValue" Text="--"
                                       Foreground="#1E88E5" FontWeight="Bold"
                                       FontSize="13" VerticalAlignment="Center"
                                       MinWidth="36" Margin="0,0,16,0"/>
                            <TextBlock Text="ΔR:" Foreground="#777777" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="NrfDeltaRValue" Text="--"
                                       Foreground="#1E88E5" FontWeight="Bold"
                                       FontSize="13" VerticalAlignment="Center" MinWidth="36"/>
                        </StackPanel>

                        <!-- Status indicators -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Ellipse x:Name="StallLeftIndicator" Width="12" Height="12" Fill="#CCCCCC" Margin="0,0,4,0"/>
                                <TextBlock Text="Stall L" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Ellipse x:Name="StallRightIndicator" Width="12" Height="12" Fill="#CCCCCC" Margin="0,0,4,0"/>
                                <TextBlock Text="Stall R" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Ellipse x:Name="EncoderFaultIndicator" Width="12" Height="12" Fill="#CCCCCC" Margin="0,0,4,0"/>
                                <TextBlock Text="Enc Fault" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="RecalibIndicator" Width="12" Height="12" Fill="#CCCCCC" Margin="0,0,4,0"/>
                                <TextBlock Text="Recalib" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Odometry Map -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#DEDEDE" BorderThickness="1"
                        CornerRadius="8" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Odometry — Robot Position &amp; Movement"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#222222" Margin="0,0,0,8"/>

                        <!-- Position readout -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="X:" Foreground="#777777" Width="22" FontSize="12"/>
                            <TextBlock x:Name="PositionXValue" Text="0.00 m"
                                       Foreground="#1E88E5" FontWeight="Bold"
                                       FontSize="12" Margin="0,0,20,0"/>
                            <TextBlock Text="Y:" Foreground="#777777" Width="22" FontSize="12"/>
                            <TextBlock x:Name="PositionYValue" Text="0.00 m"
                                       Foreground="#1E88E5" FontWeight="Bold"
                                       FontSize="12" Margin="0,0,20,0"/>
                            <TextBlock Text="θ:" Foreground="#777777" Width="22" FontSize="12"/>
                            <TextBlock x:Name="PositionThetaValue" Text="0.00°"
                                       Foreground="#1E88E5" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>

                        <!-- Map canvas -->
                        <Border Background="#FAFAFA" BorderBrush="#E0E0E0"
                                BorderThickness="1" CornerRadius="6">
                            <Viewbox Stretch="Uniform">
                                <Canvas x:Name="OdometryCanvas" Width="400" Height="280" Background="#FAFAFA">
                                    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="400" Height="280"
                                               Fill="Transparent" Stroke="#E0E0E0" StrokeThickness="1"/>
                                    <Line X1="200" Y1="0" X2="200" Y2="280" Stroke="#EEEEEE" StrokeThickness="1"/>
                                    <Line X1="0" Y1="140" X2="400" Y2="140" Stroke="#EEEEEE" StrokeThickness="1"/>
                                    <Ellipse Canvas.Left="195" Canvas.Top="135" Width="10" Height="10" Fill="#1E88E5"/>
                                    <Polygon x:Name="RobotIndicator"
                                             Points="0,0 15,-10 20,0 15,10"
                                             Fill="#E53935" Canvas.Left="195" Canvas.Top="135"/>
                                    <Polyline x:Name="MovementTrail"
                                              Stroke="#BBBBBB" StrokeThickness="1"
                                              Canvas.Left="0" Canvas.Top="0"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Log -->
                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="#DEDEDE" BorderThickness="1"
                        CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Status / Log" FontSize="13" FontWeight="Bold"
                                   Foreground="#444444" Margin="0,0,0,6"/>
                        <ListBox x:Name="StatusLogBox" Height="90"
                                 Background="#FAFAFA" BorderBrush="#E0E0E0"
                                 BorderThickness="1" Foreground="#333333"
                                 FontSize="12" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</Window>